# ─────────────────────────────────────────────────────────────
# OppHub — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────
node_modules/
package-lock.json

# ── Environment Variables (SECRETS — NEVER COMMIT) ───────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime & Temp Files ─────────────────────────────────────
temp/
tmp/
cache/
*.pid
*.seed
*.pid.lock
pids/

# ── Build Artifacts ──────────────────────────────────────────
dist/
build/
.cache/

# ── Uploaded User Files ──────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── OS Generated Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE & Editor Files ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Coverage & Testing ──────────────────────────────────────
coverage/
.nyc_output/
*.lcov
